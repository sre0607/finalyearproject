# =========================================================================
#                     FLORISH BACKEND CONFIGURATION TEMPLATE
# =========================================================================
# Copy this file to a new file named '.env' in this same directory and replace
# the values with your actual system parameters.
#
# IMPORTANT: NEVER commit your actual '.env' file containing active credentials
# to public repositories. Keep it local-only!
# =========================================================================

# The active port on which the Express REST API server will run
PORT=5000

# The execution environment. Use 'development' for local coding/debugging,
# and 'production' for active server deployment.
NODE_ENV=production

# MongoDB Connection String URI.
# For local databases: mongodb://127.0.0.1:27017/florish
# For Cloud databases: mongodb+srv://<username>:<password>@cluster.mongodb.net/florish
MONGO_URI=your_mongodb_connection_string

# JSON Web Token (JWT) Cryptographic Secret Key.
# Ensure this is a long, complex, random string to safeguard user login tokens.
JWT_SECRET=your_secret_key

# JWT Token expiration period (e.g., 30d = 30 days, 24h = 24 hours)
JWT_EXPIRE=30d

# Production Frontend URL for secure CORS configuration
FRONTEND_URL=https://your-frontend-static-site.onrender.com

# Default Administrator Configs (Configurable Seeding parameters)
ADMIN_EMAIL=your_admin_email@example.com
ADMIN_PASSWORD=your_admin_secure_password
ADMIN_NAME="Your Admin Name"

